{
  "name": "SOSEvent",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "User who triggered SOS"
    },
    "lat": {
      "type": "number",
      "description": "Latitude at SOS trigger"
    },
    "lng": {
      "type": "number",
      "description": "Longitude at SOS trigger"
    },
    "status": {
      "type": "string",
      "enum": [
        "active",
        "resolved",
        "false_alarm"
      ],
      "default": "active"
    },
    "contacts_notified": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of phone numbers notified"
    },
    "resolved_at": {
      "type": "string",
      "description": "ISO timestamp when resolved"
    }
  },
  "required": [
    "lat",
    "lng"
  ],
  "rls": {
    "create": {
      "data.user_id": "{{user.id}}"
    },
    "read": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    }
  }
}