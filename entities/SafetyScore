{
  "name": "SafetyScore",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "User ID"
    },
    "total_points": {
      "type": "number",
      "default": 0
    },
    "safe_trips": {
      "type": "number",
      "default": 0
    },
    "reports_submitted": {
      "type": "number",
      "default": 0
    },
    "check_ins": {
      "type": "number",
      "default": 0
    },
    "badges": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "Earned badge IDs"
    },
    "streak_days": {
      "type": "number",
      "default": 0
    },
    "last_activity": {
      "type": "string",
      "description": "ISO date of last activity"
    }
  },
  "required": [
    "user_id"
  ],
  "rls": {
    "create": {
      "data.user_id": "{{user.id}}"
    },
    "read": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "update": {
      "$or": [
        {
          "data.user_id": "{{user.id}}"
        },
        {
          "user_condition": {
            "role": "admin"
          }
        }
      ]
    },
    "delete": {
      "user_condition": {
        "role": "admin"
      }
    }
  }
}